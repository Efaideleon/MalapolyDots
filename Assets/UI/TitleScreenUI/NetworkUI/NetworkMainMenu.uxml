            </ui:VisualElement>
            <ui:VisualElement name="purchase-btn-container" enabled="true" class="dbr-btn dbr-btn-blue" style="flex-grow: 0; display: flex; background-color: rgba(0, 0, 255, 0);">
                <ui:Button text="8" name="CreateGameButton" class="button" style="margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; width: 260px; height: 60px; font-size: 24px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
                    <ui:VisualElement name="blurred-shadow" class="dbr-btn" style="flex-grow: 1; width: 110%; visibility: visible;"/>
